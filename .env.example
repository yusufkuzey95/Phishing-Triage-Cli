# Copy this file to ".env" and fill in your real API keys.
# The real .env file is git-ignored and must never be committed.

# Get a free key at https://www.virustotal.com/ (sign up -> profile -> API key)
VIRUSTOTAL_API_KEY=

# Get a free key at https://www.abuseipdb.com/ (sign up -> account -> API)
ABUSEIPDB_API_KEY=

# Optional: enables the AI summary (--ai-summary). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
